---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import { getEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'legal'>;
}
const { entry } = Astro.props;
const { title, description } = entry.data;

const home = await getEntry('home', 'home');
---

<BaseLayout title={title} description={description ?? title} noindex>
  <Header homeLink label={home!.data.name} />

  <main id="main">
    <article class="container legal">
      <h1>{title}</h1>
      <div class="prose">
        <slot />
      </div>
    </article>
  </main>

  <Footer />
</BaseLayout>

<style>
  .legal {
    max-width: 760px;
    padding-block: var(--space-8) var(--space-16);
  }

  h1 {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-8);
  }

  .prose :global(p),
  .prose :global(ul) {
    margin-bottom: var(--space-4);
  }

  .prose :global(ul) {
    padding-left: var(--space-6);
  }

  .prose :global(li) {
    margin-bottom: var(--space-2);
  }

  .prose :global(a) {
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .prose :global(h2),
  .prose :global(h3) {
    margin-block: var(--space-8) var(--space-3);
    font-size: var(--text-md);
  }
</style>
