---
import { ClientRouter } from 'astro:transitions';
import { Font } from 'astro:assets';
import { getEntry } from 'astro:content';

import '../styles/tokens.css';
import '../styles/global.css';
import '../styles/animations.css';

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
}

const settings = await getEntry('site', 'settings');
const seo = settings!.data.seo;

const {
  title = seo.title,
  description = seo.description,
  noindex = false,
} = Astro.props;

const pageTitle = title === seo.title ? title : `${title} — ${seo.title}`;

// build.format: 'file' отдаёт pathname вида /index.html или /animi.html,
// а публичные URL — без расширения. Приводим canonical к ним.
const cleanPath = Astro.url.pathname
  .replace(/\/index\.html$/, '/')
  .replace(/\.html$/, '');
const canonical = new URL(cleanPath, Astro.site).href;

// BASE_URL приходит и как '/', и как '/repo/' — нормализуем, чтобы не склеить путь без слеша.
const withBase = (path: string) =>
  `${import.meta.env.BASE_URL.replace(/\/$/, '')}/${path.replace(/^\//, '')}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href={withBase('favicon.svg')} type="image/svg+xml" />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />

    <Font cssVariable="--font-poppins" preload />
    <ClientRouter />

    {/* Сигнал для CSS-фолбэка: прячем .reveal только если сможем показать обратно. */}
    <script is:inline>
      document.documentElement.classList.add('js');
    </script>
  </head>

  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <slot />

    <script>
      // Фолбэк появления при скролле для браузеров без scroll-driven animations.
      const supportsScrollTimeline = CSS.supports('animation-timeline: view()');
      const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (!supportsScrollTimeline && !reduced) {
        const reveal = (root: ParentNode = document) => {
          const targets = root.querySelectorAll<HTMLElement>('.reveal:not(.is-visible)');
          if (!('IntersectionObserver' in window)) {
            targets.forEach((el) => el.classList.add('is-visible'));
            return;
          }
          const io = new IntersectionObserver(
            (entries) => {
              for (const entry of entries) {
                if (!entry.isIntersecting) continue;
                entry.target.classList.add('is-visible');
                io.unobserve(entry.target);
              }
            },
            { rootMargin: '0px 0px -12% 0px' },
          );
          targets.forEach((el) => io.observe(el));
        };

        reveal();
        // View Transitions подменяют DOM — переинициализируем после навигации.
        document.addEventListener('astro:page-load', () => reveal());
      }
    </script>
  </body>
</html>
