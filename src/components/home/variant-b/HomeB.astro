---
import { getCollection, getEntry, render } from 'astro:content';
import Header from '../../layout/Header.astro';
import Footer from '../../layout/Footer.astro';
import MobileGate from '../../layout/MobileGate.astro';
import ProjectCard from '../ProjectCard.astro';

const settings = await getEntry('site', 'settings');
const home = await getEntry('home', 'home');
const { headline, facts, projectOrder } = home!.data;
const { Content } = await render(home!);

const all = await getCollection('projects', ({ data }) => !data.draft);
const projects = projectOrder
  .map((slug) => all.find((p) => p.data.slug === slug))
  .filter((p): p is (typeof all)[number] => Boolean(p));

const gated = settings!.data.mobileGateEnabled;
---

<Header />

<main id="main">
  <section class="container hero">
    <h1>{headline}</h1>
  </section>

  <section class="container statement">
    <div class="bio"><Content /></div>
  </section>

  <section class="container">
    <dl class="facts">
      {
        facts.map((fact) => (
          <div class="reveal">
            <dt>{fact.label}</dt>
            <dd>{fact.value}</dd>
          </div>
        ))
      }
    </dl>
  </section>

  {gated && <MobileGate />}

  <section class="container projects" class:list={[{ 'desktop-only': gated }]}>
    <div class="head">
      <h2>Selected projects</h2>
      <span class="count">{String(projects.length).padStart(2, '0')}</span>
    </div>
    <div class="grid">
      {projects.map((project, i) => <ProjectCard project={project} loading={i < 2 ? 'eager' : 'lazy'} />)}
    </div>
  </section>
</main>

<Footer />

<style>
  .hero {
    padding-block: var(--space-16) var(--space-8);
  }

  h1 {
    font-size: var(--text-3xl);
    font-weight: 600;
    letter-spacing: -0.02em;
    max-width: 18ch;
  }

  .statement {
    padding-block: var(--space-8) var(--space-16);
  }

  /* Био уходит в правую половину — воздух слева держит ритм. */
  .bio {
    margin-left: auto;
    max-width: 62ch;
    font-size: var(--text-md);
  }

  .facts {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--space-6);
    padding-block: var(--space-8);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  dt {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin-bottom: var(--space-2);
  }

  dd {
    margin: 0;
    font-size: var(--text-md);
  }

  .projects {
    padding-block: var(--space-24) 0;
  }

  .head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: var(--space-12);
  }

  h2 {
    font-size: var(--text-2xl);
    font-weight: 600;
  }

  .count {
    color: var(--color-text-muted);
    font-variant-numeric: tabular-nums;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-16) var(--space-8);
  }

  @media (max-width: 900px) {
    .hero {
      padding-block: var(--space-8) var(--space-4);
    }

    .bio {
      margin-left: 0;
    }

    .facts {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: var(--space-8) var(--space-6);
    }

    .projects {
      padding-block: var(--space-16) 0;
    }

    .grid {
      grid-template-columns: 1fr;
      gap: var(--space-12);
    }
  }
</style>
