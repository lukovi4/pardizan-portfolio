---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
  /** Карточки в оригинале идут «лесенкой»: чётные смещены вниз. */
  offset?: boolean;
  loading?: 'eager' | 'lazy';
}

const { project, offset = false, loading = 'lazy' } = Astro.props;
const { name, slug, roles, cover, logo } = project.data;

const href = `${import.meta.env.BASE_URL.replace(/\/$/, '')}/${slug}`;
---

<a class="card reveal" class:list={[{ offset }]} href={href}>
  {
    cover && (
      <div class="cover">
        <Image
          src={cover}
          alt=""
          widths={[560, 1120]}
          sizes="(max-width: 900px) 100vw, 560px"
          loading={loading}
          style={`view-transition-name: cover-${slug}`}
        />
      </div>
    )
  }

  <div class="meta">
    {logo && <Image src={logo} alt="" class="logo" width={100} height={100} loading="lazy" />}
    <h3>{name}</h3>
    {roles && <p class="roles">{roles.join(', ')}</p>}
  </div>
</a>

<style>
  .card {
    display: block;
    color: inherit;
  }

  .cover {
    overflow: hidden;
    border-radius: var(--radius);
    background: var(--color-surface);
    aspect-ratio: 1;
  }

  .cover :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 400ms var(--ease);
  }

  .card:hover .cover :global(img) {
    transform: scale(1.03);
  }

  .meta {
    position: relative;
    padding-top: var(--space-6);
  }

  .logo {
    width: 56px;
    height: 56px;
    object-fit: contain;
    margin-bottom: var(--space-3);
  }

  h3 {
    font-size: var(--text-xl);
    font-weight: 600;
  }

  .roles {
    margin-top: var(--space-1);
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }

  @media (min-width: 901px) {
    .offset {
      margin-top: var(--space-16);
    }
  }
</style>
