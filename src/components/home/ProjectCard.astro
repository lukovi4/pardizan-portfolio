---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
  /** Карточки в оригинале идут «лесенкой»: чётные смещены вниз. */
  offset?: boolean;
  loading?: 'eager' | 'lazy';
}

const { project, offset = false, loading = 'lazy' } = Astro.props;
const { name, slug, roles, cover, coverVideo, logo } = project.data;

const href = `${import.meta.env.BASE_URL.replace(/\/$/, '')}/${slug}`;

// Беззвучное зацикленное видео без контролов — ведёт себя как живая обложка.
const videoSrc = coverVideo
  ? `https://kinescope.io/embed/${coverVideo}?autoplay=1&muted=1&loop=1&controls=false&playsInline=1`
  : null;
---

<a class="card reveal" class:list={[{ offset }]} href={href}>
  {
    (cover || videoSrc) && (
      <div class="cover" style={`view-transition-name: cover-${slug}`}>
        {cover && (
          <Image
            class="poster"
            src={cover}
            alt=""
            widths={[560, 1120]}
            sizes="(max-width: 900px) 100vw, 560px"
            loading={loading}
          />
        )}
        {videoSrc && (
          <iframe
            class="video"
            src={videoSrc}
            title={`${name} preview`}
            loading="lazy"
            allow="autoplay; encrypted-media; picture-in-picture"
            frameborder="0"
          />
        )}
      </div>
    )
  }

  <div class="meta">
    {logo && <Image src={logo} alt="" class="logo" width={100} height={100} loading="lazy" />}
    <h3>{name}</h3>
    {roles && <p class="roles">{roles.join(', ')}</p>}
  </div>
</a>

<style>
  .card {
    display: block;
    color: inherit;
  }

  .cover {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius);
    background: var(--color-surface);
    aspect-ratio: 1;
  }

  .poster,
  .video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .poster {
    object-fit: cover;
    transition: transform 400ms var(--ease);
  }

  /* Видео лежит поверх постера; пока грузится — виден постер. */
  .video {
    z-index: 1;
  }

  .card:hover .poster {
    transform: scale(1.03);
  }

  /* Уважаем reduced-motion: прячем автоиграющее видео, оставляем постер. */
  @media (prefers-reduced-motion: reduce) {
    .video {
      display: none;
    }
  }

  .meta {
    position: relative;
    padding-top: var(--space-6);
  }

  .logo {
    width: 56px;
    height: 56px;
    object-fit: contain;
    margin-bottom: var(--space-3);
  }

  h3 {
    font-size: var(--text-xl);
    font-weight: 600;
  }

  .roles {
    margin-top: var(--space-1);
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }

  @media (min-width: 901px) {
    .offset {
      margin-top: var(--space-16);
    }
  }
</style>
