---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import StoreBadges from './StoreBadges.astro';

interface Props {
  project: CollectionEntry<'projects'>;
}
const { project } = Astro.props;
const { title, slug, intro, logo, cover, coverVideo, stores } = project.data;

const videoSrc = coverVideo
  ? `https://kinescope.io/embed/${coverVideo}?autoplay=1&muted=1&loop=1&controls=false&playsInline=1`
  : null;
---

<header class="hero container">
  <div class="text">
    {logo && <Image src={logo} alt="" class="logo" width={72} height={72} />}
    <h1>{title}</h1>
    <p class="intro">{intro}</p>
    {stores && <StoreBadges stores={stores} />}
  </div>

  {
    (cover || videoSrc) && (
      <div class="media" style={`view-transition-name: cover-${slug}`}>
        {cover && <Image class="poster" src={cover} alt="" widths={[560, 1120]} sizes="(max-width: 900px) 100vw, 480px" loading="eager" />}
        {videoSrc && <iframe class="video" src={videoSrc} title={`${project.data.name} preview`} loading="eager" allow="autoplay; encrypted-media; picture-in-picture" frameborder="0" />}
      </div>
    )
  }
</header>

<style>
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 480px);
    gap: var(--space-12);
    align-items: start;
    padding-block: var(--space-8) var(--space-16);
  }

  .logo {
    width: 64px;
    height: 64px;
    object-fit: contain;
    margin-bottom: var(--space-6);
  }

  h1 {
    font-size: var(--text-2xl);
    font-weight: 700;
    margin-bottom: var(--space-6);
  }

  .intro {
    max-width: 60ch;
    color: var(--color-text);
  }

  .media {
    position: relative;
    aspect-ratio: 1;
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--color-surface);
  }

  .poster,
  .video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border: 0;
  }

  .video {
    z-index: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .video {
      display: none;
    }
  }

  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
      gap: var(--space-8);
      padding-block: var(--space-4) var(--space-8);
    }
  }
</style>
