---
// Повторяет поведение Tilda: на узких экранах кейсы прячутся за заглушкой.
// Включается флагом mobileGateEnabled в src/content/site/settings.json.
---

<div class="gate">
  <p class="shrug" aria-hidden="true">🤷🏻‍♂️</p>
  <p>To see my works please open website from desktop.</p>
</div>

<style>
  .gate {
    display: none;
  }

  @media (max-width: 640px) {
    .gate {
      display: block;
      padding-block: var(--space-16);
      text-align: center;
      color: var(--color-text-muted);
    }

    .shrug {
      font-size: var(--text-3xl);
      margin-bottom: var(--space-4);
    }

    /* Прячем всё, что помечено как «только для десктопа». */
    :global(.desktop-only) {
      display: none;
    }
  }
</style>
